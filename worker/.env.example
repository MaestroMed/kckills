# ════════════════════════════════════════════════════════════════════
# KCKILLS Worker — Python asyncio pipeline
# Copie en .env et remplis. Jamais commit ce fichier.
# ════════════════════════════════════════════════════════════════════

# ─── Supabase (service role = full write access, contourne RLS) ──────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── LoL Esports API (cle publique partagee par la communaute) ───────
# Cette cle est la meme pour tous les clients, pas besoin de compte
LOLESPORTS_API_KEY=0TvQnueqKa5mxJntVWt0w4LpLfEkrV1Ta8rQBb9Z

# ─── Cloudflare R2 (stockage clips + thumbs + OG images) ─────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=kckills-clips
R2_PUBLIC_URL=https://clips.kckills.com

# ─── YouTube Data API v3 (fallback VOD search) ───────────────────────
# Free tier : 10 000 quota units/day
YOUTUBE_API_KEY=

# ─── Gemini 2.5 Flash-Lite (analyse des clips) ───────────────────────
# Free tier : 1000 RPD, 15 RPM
GEMINI_API_KEY=

# ─── Claude Haiku 4.5 (moderation commentaires) — OPTIONNEL ──────────
# Si vide, les commentaires sont auto-approuves (dev only)
# ANTHROPIC_API_KEY=

# ─── Discord Webhook (logs + alertes worker) ─────────────────────────
DISCORD_WEBHOOK_URL=

# ─── Team cible (pour la v0 : Karmine Corp uniquement) ───────────────
TRACKED_TEAM_SLUG=karmine-corp
TRACKED_TEAM_CODE=KC

# ─── Runtime settings ────────────────────────────────────────────────
LOG_LEVEL=INFO
WORKER_HOSTNAME=mehdi-pc
