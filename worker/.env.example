# ════════════════════════════════════════════════════════════════════
# KCKILLS / LoLTok Worker — Python asyncio pipeline
# Copie en .env et remplis. Ce fichier ne doit jamais etre commit.
# ════════════════════════════════════════════════════════════════════

# ─── Supabase (service role = full write, contourne RLS) ─────────────
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── LoL Esports API (cle publique partagee par la communaute) ───────
# Meme cle pour tous les clients, pas besoin de compte Riot
LOLESPORTS_API_KEY=0TvQnueqKa5mxJntVWt0w4LpLfEkrV1Ta8rQBb9Z

# ─── Cloudflare R2 (stockage clips + thumbs + OG images) ─────────────
# https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kckills-clips
# Custom domain connected in R2 settings (ex: https://clips.kckills.com).
# Leave empty to fall back to the r2.cloudflarestorage.com URL (dev only).
R2_PUBLIC_URL=https://clips.kckills.com

# ─── YouTube Data API v3 (fallback VOD search) ───────────────────────
# Free tier: 10,000 quota units / day. search.list costs 100 units.
# Only used when getEventDetails.vod.parameter is missing.
YOUTUBE_API_KEY=

# ─── Gemini 2.5 Flash-Lite (analyse des clips) ───────────────────────
# https://aistudio.google.com/apikey
# Free tier: 1000 RPD, 15 RPM. NE JAMAIS envoyer de donnees users (prompts logged by Google).
GEMINI_API_KEY=

# ─── Claude Haiku 4.5 (moderation commentaires) — OPTIONNEL ──────────
# Si vide, les commentaires sont auto-approuves (dev / low-traffic only).
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# ─── Discord Webhook (logs + alertes + rapport quotidien) ────────────
# Crée un webhook dans un channel #worker-logs (Server Settings → Integrations).
DISCORD_WEBHOOK_URL=

# ─── Team cible (v0 : Karmine Corp uniquement) ───────────────────────
TRACKED_TEAM_SLUG=karmine-corp
TRACKED_TEAM_CODE=KC

# ─── Runtime ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
WORKER_HOSTNAME=mehdi-pc
