# ════════════════════════════════════════════════════════════════════
# KCKILLS / LoLTok Worker — Python asyncio pipeline
# Copie en .env et remplis. Ce fichier ne doit jamais etre commit.
# ════════════════════════════════════════════════════════════════════

# ─── Supabase (service role = full write, contourne RLS) ─────────────
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── LoL Esports API (cle publique partagee par la communaute) ───────
# Meme cle pour tous les clients, pas besoin de compte Riot
LOLESPORTS_API_KEY=0TvQnueqKa5mxJntVWt0w4LpLfEkrV1Ta8rQBb9Z

# ─── Cloudflare R2 (stockage clips + thumbs + OG images) ─────────────
# https://dash.cloudflare.com/?to=/:account/r2/api-tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kckills-clips
# Custom domain connected in R2 settings (ex: https://clips.kckills.com).
# Leave empty to fall back to the r2.cloudflarestorage.com URL (dev only).
R2_PUBLIC_URL=https://clips.kckills.com

# ─── YouTube Data API v3 (fallback VOD search) ───────────────────────
# Free tier: 10,000 quota units / day. search.list costs 100 units.
# Only used when getEventDetails.vod.parameter is missing.
YOUTUBE_API_KEY=

# ─── YouTube auth cookies (clipper download access) ──────────────────
# Why : YouTube anti-bot returns "Sign in to confirm" on EVERY yt-dlp
# download from a fresh IP. Without auth cookies the clipper produces
# zero clips → zero published kills.
#
# Recommended (scalable, zero-maintenance) — Firefox profile :
#   1. Install Firefox if not present : winget install Mozilla.Firefox
#   2. Create a dedicated profile :
#      "C:\Program Files\Mozilla Firefox\firefox.exe" -CreateProfile "kckills-scraper"
#   3. Open Firefox with that profile + sign into YouTube ONCE :
#      "C:\Program Files\Mozilla Firefox\firefox.exe" -P "kckills-scraper" https://youtube.com
#   4. Close Firefox. Don't reuse this profile for browsing.
#   5. Set this env var :
KCKILLS_YT_COOKIES_FIREFOX_PROFILE=kckills-scraper
#
# Why Firefox not Chrome : Chrome 127+ App-Bound Encryption blocks
# every programmatic cookie extraction (browser_cookie3, --cookies-from-browser,
# DPAPI). Firefox doesn't have ABE — yt-dlp reads cookies.sqlite directly.
#
# Fallback (legacy, requires periodic re-export) :
# KCKILLS_YT_COOKIES_FILE=C:\path\to\youtube_cookies.txt
#
# Fallback (broken on Chrome 127+, kept for reference) :
# KCKILLS_YT_COOKIES_CHROME_PROFILE=Profile 5

# ─── Gemini 2.5 Flash-Lite (analyse des clips) ───────────────────────
# https://aistudio.google.com/apikey
# Free tier: 1000 RPD, 15 RPM. NE JAMAIS envoyer de donnees users (prompts logged by Google).
GEMINI_API_KEY=

# ─── Claude Haiku 4.5 (moderation commentaires) — OPTIONNEL ──────────
# Si vide, les commentaires sont auto-approuves (dev / low-traffic only).
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# ─── Discord Webhook (logs + alertes + rapport quotidien) ────────────
# Crée un webhook dans un channel #worker-logs (Server Settings → Integrations).
DISCORD_WEBHOOK_URL=

# ─── Riot API key (Production tier) ──────────────────────────────────
# Partage la meme valeur que web/.env.local RIOT_API_KEY.
# Utilisee par : (a) le worker pour les futurs endpoints stats,
# (b) le frontend /api/auth/riot/callback pour league-v4 + mastery-v4.
# Sans cle Production, le link Riot sur /settings fonctionne mais
# n'affiche ni rank ni top champions.
RIOT_API_KEY=your-riot-api-key

# ─── Team cible (v0 : Karmine Corp uniquement) ───────────────────────
TRACKED_TEAM_SLUG=karmine-corp
TRACKED_TEAM_CODE=KC

# ─── Runtime ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
WORKER_HOSTNAME=mehdi-pc
