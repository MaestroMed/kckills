# ════════════════════════════════════════════════════════════════════
# KCKILLS — Frontend (Next.js) environment
# Copie ce fichier en .env.local et remplis les valeurs.
# Les NEXT_PUBLIC_* sont expose au client (browser).
# Tout le reste reste serveur-only.
# ════════════════════════════════════════════════════════════════════

# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kckills.com
# Used by /api/auth/riot/* as the canonical origin for the RSO redirect
# URI. Falls back to NEXT_PUBLIC_SITE_URL when unset, but defining it
# explicitly here makes the linking flow self-documenting.
NEXT_PUBLIC_APP_URL=https://kckills.com

# ─── Supabase (DB + Auth) ────────────────────────────────────────────
# Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role (SECRET, jamais expose cote client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Discord OAuth ───────────────────────────────────────────────────
# Discord Developer Portal > Your App > OAuth2
# (Utilise uniquement cote serveur, Supabase gere le flow pour toi)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── Riot Sign On (OPTIONNEL — lien rang + champions favoris) ────────
# Developer Portal Riot > Apps > Production access requise pour les
# endpoints league-v4 et champion-mastery-v4. Sans cles : la page
# /settings affiche "indisponible" et /api/auth/riot/start renvoie 503.
RIOT_CLIENT_ID=
RIOT_CLIENT_SECRET=
# Cle API Riot serveur (X-Riot-Token) pour ranked + mastery. Optionnel :
# si vide ou egal a "your-riot-api-key", le compte sera lie sans rank/champs.
# La meme cle vit aussi dans worker/.env (utilisee par les modules backend).
RIOT_API_KEY=
# Optionnel : secret HMAC pour signer le cookie PKCE pendant le flow.
# Si non defini, on retombe sur SUPABASE_SERVICE_ROLE_KEY (deja serveur-only).
RIOT_OAUTH_COOKIE_SECRET=

# ─── Cloudflare R2 (clips, thumbs, OG images) ────────────────────────
# L'URL publique de ton bucket (custom domain OU bucket.r2.dev)
NEXT_PUBLIC_R2_PUBLIC_URL=https://clips.kckills.com
# R2 API credentials (cote serveur pour ecrire, normalement utilise par le worker)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=kckills-clips

# ─── PWA Push Notifications (VAPID) ──────────────────────────────────
# Generate avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:kckillsloltok@gmail.com

# ─── Analytics Umami (self-hosted, privacy-first) ───────────────────
# Laisse vide pour desactiver. Le script n'est injecte que si les deux
# variables sont definies (voir src/app/layout.tsx).
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ─── Sentry — error tracking (Wave 11 / DB) ──────────────────────────
# Free tier 5K events/mo. Sign up at https://sentry.io ; create a
# Next.js project. Without these vars, Sentry init is skipped entirely
# (zero perf cost, zero bundle bloat).
# Voir docs/sentry-setup-guide.md pour le pas-a-pas (5 min).
NEXT_PUBLIC_SENTRY_DSN=
# Same DSN by default ; override only if Node runtime should ship to a
# separate Sentry project from the browser.
SENTRY_DSN=
# Auth token for source-map upload during `next build`. Optional —
# build still succeeds without it.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Environment label shown in the Sentry UI ("production", "staging"...).
SENTRY_ENV=
# Release identifier, typically the git commit SHA. Set by deploy script.
SENTRY_RELEASE=

# ─── Rate limiting (optionnel) ───────────────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
